{
  "version": 2,
  "outputDirectory": "apps/sanjeevani-clinic/dist",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "node scripts/vercel-build.mjs",
  "functions": {
    "api/**/*.ts": {
      "runtime": "nodejs22.x",
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
